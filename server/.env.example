# ====================================
# Bank CRM API - Environment Variables
# ====================================

# ===== SERVER CONFIGURATION =====
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# ===== DATABASE =====
MONGODB_URI=mongodb://localhost:27017/bank_crm

# ===== JWT CONFIGURATION =====
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_change_in_production

# ===== ADMIN CREDENTIALS =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ===== CORS CONFIGURATION =====
CORS_ORIGIN=http://localhost:5173

# ===== LOGGING =====
LOG_LEVEL=info
